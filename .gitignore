backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/*.iml
backend/*.iws
backend/*.ipr

# IDE（全局忽略，无需子目录规则）
.idea/
.vscode/
.settings/
.project
.classpath
.factorypath
.springBeans
.sts4-cache
.nbproject/private/
/nbbuild/
/nbdist/
